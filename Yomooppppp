    nameLabel.BackgroundTransparency = 1
    nameLabel.TextColor3 = Color3.fromRGB(0, 255, 0)
    nameLabel.TextSize = 12
    nameLabel.Font = Enum.Font.GothamBold
    nameLabel.Text = player.Name
    nameLabel.Parent = billboardGui
    
    local distanceLabel = Instance.new("TextLabel")
    distanceLabel.Size = UDim2.new(1, 0, 0.3, 0)
    distanceLabel.Position = UDim2.new(0, 0, 0.4, 0)
    distanceLabel.BackgroundTransparency = 1
    distanceLabel.TextColor3 = Color3.fromRGB(0, 255, 0)
    distanceLabel.TextSize = 10
    distanceLabel.Font = Enum.Font.Gotham
    distanceLabel.Text = "0m"
    distanceLabel.Parent = billboardGui
    
    local healthBgLabel = Instance.new("TextLabel")
    healthBgLabel.Size = UDim2.new(1, 0, 0.3, 0)
    healthBgLabel.Position = UDim2.new(0, 0, 0.7, 0)
    healthBgLabel.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
    healthBgLabel.BorderSizePixel = 0
    healthBgLabel.TextTransparency = 1
    healthBgLabel.Parent = billboardGui
    
    local healthCorner = Instance.new("UICorner")
    healthCorner.CornerRadius = UDim.new(0, 2)
    healthCorner.Parent = healthBgLabel
    
    local healthFillLabel = Instance.new("TextLabel")
    healthFillLabel.Size = UDim2.new(1, 0, 1, 0)
    healthFillLabel.BackgroundColor3 = Color3.fromRGB(0, 255, 0)
    healthFillLabel.BorderSizePixel = 0
    healthFillLabel.TextTransparency = 1
    healthFillLabel.Parent = healthBgLabel
    
    local fillCorner = Instance.new("UICorner")
    fillCorner.CornerRadius = UDim.new(0, 2)
    fillCorner.Parent = healthFillLabel
    
