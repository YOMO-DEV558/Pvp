local function createToggleRow(parent, icon, label, order)
    local row = Instance.new("Frame", parent)
    row.Name              = label
    row.Size              = UDim2.new(1, 0, 0, ROW_H)
    row.BackgroundColor3  = Color3.fromRGB(22, 22, 35)
    row.BorderSizePixel   = 0
    row.LayoutOrder       = order
    Instance.new("UICorner", row).CornerRadius = UDim.new(0, 10)

    local rowStroke = Instance.new("UIStroke", row)
    rowStroke.Color     = Color3.fromRGB(40, 40, 60)
    rowStroke.Thickness = 1

    -- ✅ Full-area invisible button (touch-friendly)
    local hitArea = Instance.new("TextButton", row)
    hitArea.Size                 = UDim2.fromScale(1, 1)
    hitArea.BackgroundTransparency = 1
    hitArea.Text                 = ""
    hitArea.ZIndex               = 5

    local iconLbl = Instance.new("TextLabel", row)
    iconLbl.Size                 = UDim2.fromOffset(32, ROW_H)
    iconLbl.Position             = UDim2.fromOffset(10, 0)
    iconLbl.BackgroundTransparency = 1
    iconLbl.Font                 = Enum.Font.Gotham
    iconLbl.TextSize             = isMobile and 20 or 18
    iconLbl.Text                 = icon
    iconLbl.TextColor3           = Color3.white
    iconLbl.ZIndex               = 2

    local textLbl = Instance.new("TextLabel", row)
    textLbl.Size                 = UDim2.new(1, -96, 1, 0)
    textLbl.Position             = UDim2.fromOffset(46, 0)
    textLbl.BackgroundTransparency = 1
    textLbl.Font                 = Enum.Font.Gotham
    textLbl.TextSize             = FONT_MD
    textLbl.TextColor3           = Color3.fromRGB(200, 200, 220)
    textLbl.TextXAlignment       = Enum.TextXAlignment.Left
    textLbl.Text                 = label
    textLbl.ZIndex               = 2

    -- Pill switch (ใหญ่ขึ้นบนมือถือ)
    local pw  = isMobile and 54 or 44
    local ph  = isMobile and 28 or 22
    local psz = isMobile and 24 or 18
    local pillBg = Instance.new("Frame", row)
    pillBg.Size             = UDim2.fromOffset(pw, ph)
    pillBg.Position         = UDim2.new(1, -(pw + 8), 0.5, -ph/2)
    pillBg.BackgroundColor3 = Color3.fromRGB(50, 50, 70)
    pillBg.BorderSizePixel  = 0
    pillBg.ZIndex           = 3
    Instance.new("UICorner", pillBg).CornerRadius = UDim.new(1, 0)

    local pill = Instance.new("Frame", pillBg)
    pill.Size             = UDim2.fromOffset(psz, psz)
    pill.Position         = UDim2.fromOffset(2, (ph-psz)/2)
    pill.BackgroundColor3 = Color3.fromRGB(120, 120, 150)
    pill.BorderSizePixel  = 0
    pill.ZIndex           = 4
    Instance.new("UICorner", pill).CornerRadius = UDim.new(1, 0)

    local isOn    = false
    local onPos   = UDim2.fromOffset(pw - psz - 2, (ph-psz)/2)
    local offPos  = UDim2.fromOffset(2, (ph-psz)/2)

    local function setState(on)
        isOn = on
        TweenService:Create(pill,   TweenInfo.new(0.18, Enum.EasingStyle.Quad),
            {Position = on and onPos or offPos,
             BackgroundColor3 = on and Color3.white or Color3.fromRGB(120, 120, 150)}):Play()
        TweenService:Create(pillBg, TweenInfo.new(0.18, Enum.EasingStyle.Quad),
            {BackgroundColor3 = on and Color3.fromRGB(0, 210, 100) or Color3.fromRGB(50, 50, 70)}):Play()
        textLbl.TextColor3 = on and Color3.fromRGB(240, 255, 240) or Color3.fromRGB(200, 200, 220)
        rowStroke.Color    = on and Color3.fromRGB(0, 180, 80) or Color3.fromRGB(40, 40, 60)
    end

    -- ✅ MouseButton1Click + TouchTap
    hitArea.MouseButton1Click:Connect(function() setState(not isOn) end)
    hitArea.TouchTap:Connect(function() setState(not isOn) end)

    return row, setState, function() return isOn end, hitArea
end

