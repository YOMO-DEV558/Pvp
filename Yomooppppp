-- DOWNED FLICKER (Ghost Exploit)
-- ==========================================
local function isDowned()
    if not CharModule then return false end
    local ok, hum = pcall(function() return CharModule.get_hum() end)
    if not ok or not hum then return false end
    return hum:GetAttribute("HasBeenDowned") or hum:GetAttribute("IsDead") or hum.Health <= 0
end

local function getHRP()
    if not CharModule then return HumanoidRootPart end
    local ok, char = pcall(function() return CharModule.current_char.get() end)
    if not ok or not char then return HumanoidRootPart end
    return char:FindFirstChild("HumanoidRootPart")
end

local function teleportUnderground()
    local hrp = getHRP()
    if not hrp then return end
    undergroundBaseCFrame = hrp.CFrame + Vector3.new(0, DROP_DEPTH, 0)
    hrp.CFrame = undergroundBaseCFrame
end

local function flickerAndMove()
    if flickering then return end
    flickering = true
    task.spawn(function()
        while flickering and enabled and isDowned() do
            local hrp = getHRP()
            if hrp and undergroundBaseCFrame then
                local angle  = math.random() * math.pi * 2
                local offset = Vector3.new(math.cos(angle), 0, math.sin(angle)) * MOVE_RADIUS
                hrp.CFrame   = CFrame.new(undergroundBaseCFrame.Position + offset)
                task.wait(0.05)
                hrp.CFrame   = undergroundBaseCFrame
            end
            task.wait(FLICKER_RATE)
        end
        flickering = false
    end)
end

