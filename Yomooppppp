local function getActiveTool()
    local char = LocalPlayer.Character
    if char then
        for _, item in ipairs(char:GetChildren()) do
            if item:IsA("Tool") then return item end
        end
    end
    local bp = LocalPlayer:FindFirstChild("Backpack")
    if bp then
        for _, item in ipairs(bp:GetChildren()) do
            if item:IsA("Tool") then return item end
        end
    end
end

local function getPlayersInRange(radius)
    local res = {}
    local char = LocalPlayer.Character
    if not char or not char.PrimaryPart then return res end
    local pos = char.PrimaryPart.Position
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character and p.Character.PrimaryPart then
            local ok, mag = pcall(function()
                return (p.Character.PrimaryPart.Position - pos).Magnitude
            end)
            if ok and mag and mag <= radius then
                table.insert(res, p)
            end
        end
    end
    return res
end

local function AttackNearby()
    if not Remote then return end
    local char = LocalPlayer.Character
    if not char or not char.PrimaryPart then return end
    local tool = getActiveTool()
    if not tool or tool.Parent ~= LocalPlayer.Character then return end
    local targets = getPlayersInRange(scanRadius)
    for _, target in pairs(targets) do
        if target.Character and target.Character.PrimaryPart then
            local ok1, lPos = pcall(function() return LocalPlayer.Character.PrimaryPart.Position end)
            local ok2, ePos = pcall(function() return target.Character.PrimaryPart.Position end)
            if ok1 and ok2 then
                pcall(function()
                    CallRemote(Remote, "melee_attack", tool, {target}, CFrame.lookAt(lPos, ePos), 0.75)
                end)
            end
        end
    end
end

local function StartAutoAttack()
    if running then return end
    running = true
    task.spawn(function()
        while running do
            task.wait(scanInterval)
            if hookEnabled and LocalPlayer.Character and LocalPlayer.Character.PrimaryPart then
                pcall(AttackNearby)
            end
        end
    end)
end

