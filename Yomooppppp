    line.Color = Color3.fromRGB(255, 0, 0)
    line.Visible = false
    
    return {
        billboardGui = billboardGui,
        nameLabel = nameLabel,
        distanceLabel = distanceLabel,
        healthBgLabel = healthBgLabel,
        healthFillLabel = healthFillLabel,
        box = box,
        line = line,
        player = player
    }
end

local function updateESPBox(espData)
    if not espData or not espData.player or not espData.player.Character then
        return false
    end
    
    local character = espData.player.Character
    local humanoidRootPart = character:FindFirstChild("HumanoidRootPart")
    local humanoid = character:FindFirstChild("Humanoid")
    
    if not humanoidRootPart or not humanoid or humanoid.Health <= 0 then
        return false
    end
    
    if ESPEnabled then
        local screenPos, onScreen = Camera:WorldToViewportPoint(humanoidRootPart.Position)
        
        if onScreen then
            local size = Vector2.new(100, 150)
            espData.box.Position = Vector2.new(screenPos.X - size.X / 2, screenPos.Y - size.Y / 2)
            espData.box.Size = size
            espData.box.Visible = true
            
            local playerPos = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Head")
            if playerPos then
                espData.line.From = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y)
                espData.line.To = Vector2.new(screenPos.X, screenPos.Y)
                espData.line.Visible = true
            end
        else
            espData.box.Visible = false
            espData.line.Visible = false
        end
        
        if humanoid then
            local healthPercent = humanoid.Health / humanoid.MaxHealth
            espData.healthFillLabel.Size = UDim2.new(math.clamp(healthPercent, 0, 1), 0, 1, 0)
            
            if healthPercent > 0.5 then
                espData.healthFillLabel.BackgroundColor3 = Color3.fromRGB(0, 255, 0)
            elseif healthPercent > 0.25 then
                espData.healthFillLabel.BackgroundColor3 = Color3.fromRGB(255, 255, 0)
            else
                espData.healthFillLabel.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
            end
        end
        
        local playerHRP = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        if playerHRP then
            local distance = (humanoidRootPart.Position - playerHRP.Position).Magnitude
            espData.distanceLabel.Text = string.format("%.0fm", distance)
        end
    else
        espData.box.Visible = false
        espData.line.Visible = false
    end
    
    return true
end

