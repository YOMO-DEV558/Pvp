local function updateStartBtn()
    if farmEnabled then
        StartBtn.Text = "⏹  หยุดฟาร์ม"
        btnGrad.Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, Color3.fromRGB(220,50,50)),
            ColorSequenceKeypoint.new(1, Color3.fromRGB(160,20,20)),
        })
        btnStroke.Color = Color3.fromRGB(255,80,80)
        TweenService:Create(StartBtn, TweenInfo.new(0.15), {BackgroundColor3 = Color3.fromRGB(200,40,40)}):Play()
    else
        StartBtn.Text = "▶  เริ่มฟาร์ม"
        btnGrad.Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, Color3.fromRGB(0,230,110)),
            ColorSequenceKeypoint.new(1, Color3.fromRGB(0,150,65)),
        })
        btnStroke.Color = Color3.fromRGB(0,255,120)
        TweenService:Create(StartBtn, TweenInfo.new(0.15), {BackgroundColor3 = Color3.fromRGB(0,190,90)}):Play()
    end
end

-- ── toggleFarm ────────────────────────────────────────────────
local function toggleFarm()
    farmEnabled = not farmEnabled
    setFarmToggle(farmEnabled)
    updateStartBtn()
    -- bounce animation
    TweenService:Create(StartBtn, TweenInfo.new(0.08, Enum.EasingStyle.Quad, Enum.EasingDirection.In),
        {Size = UDim2.new(1, 0, 0, BTN_H - 6)}):Play()
    task.wait(0.09)
    TweenService:Create(StartBtn, TweenInfo.new(0.16, Enum.EasingStyle.Back, Enum.EasingDirection.Out),
        {Size = UDim2.new(1, 0, 0, BTN_H)}):Play()
    if farmEnabled then
        Character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
        Humanoid  = Character:WaitForChild("Humanoid")
        HRP       = Character:WaitForChild("HumanoidRootPart")
        task.spawn(farmLoop)
    else
        destroyMovers()
    end
    updateStatus()
end

-- ✅ PC + Mobile
StartBtn.MouseButton1Click:Connect(toggleFarm)
StartBtn.TouchTap:Connect(toggleFarm)

-- Farm pill
local function onFarmToggle()
    task.wait(0.01)
    farmEnabled = getFarmState()
    updateStartBtn()
    if farmEnabled then
        Character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
        Humanoid  = Character:WaitForChild("Humanoid")
        HRP       = Character:WaitForChild("HumanoidRootPart")
        task.spawn(farmLoop)
    else destroyMovers() end
    updateStatus()
end
farmHit.MouseButton1Click:Connect(onFarmToggle)
farmHit.TouchTap:Connect(onFarmToggle)

-- Job pill
local function onJobToggle()
    task.wait(0.01)
    if getJobState() then jobDone = false end
    updateStatus()
end
jobHit.MouseButton1Click:Connect(onJobToggle)
jobHit.TouchTap:Connect(onJobToggle)

-- ── Close / Open ──────────────────────────────────────────────
local function closeWindow()
    TweenService:Create(Main, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.In),
        {Size = UDim2.fromOffset(WIN_W, 0), BackgroundTransparency = 1}):Play()
    task.wait(0.22)
    Main.Visible = false; MiniBtn.Visible = true; pulseTween:Play()
end
local function openWindow()
    pulseTween:Cancel(); MiniBtn.Visible = false
    Main.Visible = true; Main.Size = UDim2.fromOffset(WIN_W, 0); Main.BackgroundTransparency = 0
    TweenService:Create(Main, TweenInfo.new(0.28, Enum.EasingStyle.Back, Enum.EasingDirection.Out),
        {Size = UDim2.fromOffset(WIN_W, WIN_H)}):Play()
end

-- ✅ PC + Mobile
CloseBtn.MouseButton1Click:Connect(closeWindow)
CloseBtn.TouchTap:Connect(closeWindow)
MiniBtn.MouseButton1Click:Connect(openWindow)
MiniBtn.TouchTap:Connect(openWindow)

-- ── Keyboard (PC only) ────────────────────────────────────────
if not isMobile then
    UserInputService.InputBegan:Connect(function(input, gp)
        if gp then return end
        if input.KeyCode == CONFIG.ToggleKey then toggleFarm() end
    end)
end

-- ============================================================
-- ♻️  Character Respawn
-- ============================================================
LocalPlayer.CharacterAdded:Connect(function(char)
    Character = char
    Humanoid  = char:WaitForChild("Humanoid")
    HRP       = char:WaitForChild("HumanoidRootPart")
    isTweening = false; moverBP, moverBG = nil, nil
    if farmEnabled then task.wait(1.5); task.spawn(farmLoop) end
end)

