local function SafeCall(f, ...)
    return pcall(f, ...)
end

local function getPing()
    local ok, stats = pcall(function()
        return LocalPlayer.PlayerGui:FindFirstChild("NetworkStats")
    end)
    if ok and stats then
        local lbl = stats:FindFirstChild("PingLabel")
        if lbl then
            local n = tonumber(lbl.Text:match("%d+"))
            return n and n/1000 or 0.05
        end
    end
    return 0.05
end

local function isPlayerExcluded(name)
    for _, n in ipairs(excludedPlayerNames) do
        if n ~= "" and string.find(string.lower(name), string.lower(n)) then return true end
    end
    return false
end

local function getClosestTarget()
    local closest, shortest = nil, FOVRadius
    local center = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character then
            local head = p.Character:FindFirstChild("Head")
            local hum  = p.Character:FindFirstChild("Humanoid")
            local hrp  = p.Character:FindFirstChild("HumanoidRootPart")
            if head and hum and hum.Health > 0 and hrp then
                local sp, onScreen = Camera:WorldToViewportPoint(head.Position)
                if onScreen then
                    local d = (Vector2.new(sp.X,sp.Y) - center).Magnitude
                    if d <= FOVRadius and not isPlayerExcluded(p.Name) and d < shortest then
                        shortest = d
                        closest  = p
                    end
                end
            end
        end
    end
    return closest
end

-- Prediction ดีขึ้น: คำนวณ velocity + ping + gravity compensation
local function predictPosition(head, hrp)
    if not head or not hrp then return head and head.Position or Vector3.zero end
    local ping     = getPing()
    local vel      = hrp.AssemblyLinearVelocity or hrp.Velocity or Vector3.zero
    -- คำนวณ gravity offset ถ้าอยู่กลางอากาศ
    local gravComp = Vector3.new(0, -workspace.Gravity * ping * ping * 0.5, 0)
    return head.Position + (vel * ping * 1.25) + gravComp
end

-- Wall check แบบใหม่ใช้ Raycast API ทันสมัย
local function isBehindWallSA(fromPos, toPos, targetChar)
    local params = RaycastParams.new()
    local ignore = {Camera}
    if LocalPlayer.Character then table.insert(ignore, LocalPlayer.Character) end
    if targetChar then table.insert(ignore, targetChar) end
    params.FilterDescendantsInstances = ignore
    params.FilterType = Enum.RaycastFilterType.Exclude
    params.IgnoreWater = true
    local dir = toPos - fromPos
    local res = Workspace:Raycast(fromPos, dir.Unit * dir.Magnitude, params)
    if res then return true, res.Instance, res.Position end
    return false, nil, nil
end

-- CallRemote (ใช้ CounterTable เพื่อไม่โดน kick)
local function CallRemote(remote, ...)
    if not remote then return end
    local args = {...}
    if remote.ClassName == "RemoteEvent" then
        if CounterTable and type(CounterTable.event) == "number" then
            CounterTable.event = CounterTable.event + 1
            SafeCall(function(...) remote:FireServer(CounterTable.event, ...) end, tu_unpack(args))
        else
            localEventCounter = localEventCounter + 1
            SafeCall(function(...) remote:FireServer(localEventCounter, ...) end, tu_unpack(args))
        end
    elseif remote.ClassName == "RemoteFunction" then
        if CounterTable and type(CounterTable.func) == "number" then
            CounterTable.func = CounterTable.func + 1
            local ok, r = SafeCall(function(...) return remote:InvokeServer(CounterTable.func, ...) end, tu_unpack(args))
            return ok and r or nil
        else
            localFuncCounter = localFuncCounter + 1
            local ok, r = SafeCall(function(...) return remote:InvokeServer(localFuncCounter, ...) end, tu_unpack(args))
            return ok and r or nil
        end
    end
end

local function NetGet(...)
    if not CounterTable then return end
    CounterTable.func = (CounterTable.func or 0) + 1
    local ok, res = pcall(function(...)
        local GetRemote = Remotes:WaitForChild("Get")
        return GetRemote:InvokeServer(CounterTable.func, ...)
    end, ...)
    return ok and res or nil
end

