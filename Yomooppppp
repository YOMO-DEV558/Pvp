-- ===========================
-- NO RECOIL - CAMERA STABILIZATION
-- ===========================

local originalCameraPos = nil

RunService.RenderStepped:Connect(function()
    if NoRecoilEnabled and LocalPlayer.Character then
        local humanoid = LocalPlayer.Character:FindFirstChild("Humanoid")
        
        if humanoid and humanoid.Health > 0 then
            if not originalCameraPos then
                originalCameraPos = Camera.CFrame
            end
            
            local currentCFrame = Camera.CFrame
            local targetCFrame = originalCameraPos
            
            Camera.CFrame = CFrame.new(
                targetCFrame.Position + (currentCFrame.Position - targetCFrame.Position) * 0.95,
                currentCFrame.Position + currentCFrame.LookVector
            )
        end
    else
        originalCameraPos = nil
    end
end)

-- ===========================
-- ESP UPDATE LOOP
-- ===========================

RunService.RenderStepped:Connect(function()
    if ESPEnabled then
        for player, espData in pairs(ESPObjects) do
            if not updateESPBox(espData) then
                if espData.billboardGui then
                    espData.billboardGui:Destroy()
                end
                if espData.box then
                    espData.box:Remove()
                end
                ESPObjects[player] = nil
            end
        end
    end
end)

