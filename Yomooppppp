-- ── Helper: สร้าง Toggle Row ──────────────────────────────────
local function createToggleRow(parent, icon, label, layoutOrder)
    local row = Instance.new("Frame", parent)
    row.Name = label
    row.Size = UDim2.new(1, 0, 0, 44)
    row.BackgroundColor3 = Color3.fromRGB(22, 22, 35)
    row.BorderSizePixel = 0
    row.LayoutOrder = layoutOrder
    Instance.new("UICorner", row).CornerRadius = UDim.new(0, 8)

    local rowStroke = Instance.new("UIStroke", row)
    rowStroke.Color = Color3.fromRGB(40, 40, 60)
    rowStroke.Thickness = 1

    local iconLbl = Instance.new("TextLabel", row)
    iconLbl.Size = UDim2.fromOffset(30, 44)
    iconLbl.Position = UDim2.fromOffset(8, 0)
    iconLbl.BackgroundTransparency = 1
    iconLbl.Font = Enum.Font.Gotham
    iconLbl.TextSize = 18
    iconLbl.Text = icon
    iconLbl.TextColor3 = Color3.white

    local textLbl = Instance.new("TextLabel", row)
    textLbl.Size = UDim2.new(1, -90, 1, 0)
    textLbl.Position = UDim2.fromOffset(40, 0)
    textLbl.BackgroundTransparency = 1
    textLbl.Font = Enum.Font.Gotham
    textLbl.TextSize = 13
    textLbl.TextColor3 = Color3.fromRGB(200, 200, 220)
    textLbl.TextXAlignment = Enum.TextXAlignment.Left
    textLbl.Text = label

    -- Toggle pill
    local pillBg = Instance.new("Frame", row)
    pillBg.Size = UDim2.fromOffset(44, 22)
    pillBg.Position = UDim2.new(1, -52, 0.5, -11)
    pillBg.BackgroundColor3 = Color3.fromRGB(50, 50, 70)
    pillBg.BorderSizePixel = 0
    Instance.new("UICorner", pillBg).CornerRadius = UDim.new(1, 0)

    local pill = Instance.new("Frame", pillBg)
    pill.Size = UDim2.fromOffset(18, 18)
    pill.Position = UDim2.fromOffset(2, 2)
    pill.BackgroundColor3 = Color3.fromRGB(120, 120, 150)
    pill.BorderSizePixel = 0
    Instance.new("UICorner", pill).CornerRadius = UDim.new(1, 0)

    -- state
    local isOn = false
    local function setState(on)
        isOn = on
        local targetX = on and UDim2.fromOffset(24, 2) or UDim2.fromOffset(2, 2)
        local targetColor = on and Color3.fromRGB(0, 210, 100) or Color3.fromRGB(50, 50, 70)
        local pillColor = on and Color3.white or Color3.fromRGB(120, 120, 150)
        TweenService:Create(pill, TweenInfo.new(0.18, Enum.EasingStyle.Quad), {Position = targetX, BackgroundColor3 = pillColor}):Play()
        TweenService:Create(pillBg, TweenInfo.new(0.18, Enum.EasingStyle.Quad), {BackgroundColor3 = targetColor}):Play()
        textLbl.TextColor3 = on and Color3.fromRGB(240, 255, 240) or Color3.fromRGB(200, 200, 220)
        rowStroke.Color = on and Color3.fromRGB(0, 180, 80) or Color3.fromRGB(40, 40, 60)
    end

    row.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 or
           inp.UserInputType == Enum.UserInputType.Touch then
            setState(not isOn)
            row:FireCustomEvent("Toggled", isOn)
        end
    end)

    return row, setState, function() return isOn end
end

