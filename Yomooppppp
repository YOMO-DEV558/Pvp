-- ⚙️  CONFIG
-- ============================================================
local CONFIG = {
    BoxKeywords    = {"Box", "Crate", "Chest", "block", "กล่อง"},
    ReachDistance  = 5,
    TweenSpeed     = 0.35,
    PickupDelay    = 0.2,
    ScanInterval   = 0.8,
    ScanRadius     = 300,

    -- ชื่อ NPC / Part ที่ใช้สมัครงาน (ปรับตามเกม)
    JobNPCKeywords = {"JobNPC", "register", "สมัคร", "Recruiter", "Manager", "job", "Worker", "Employer", "hire"},
    JobReachDist   = 4,

    ToggleKey      = Enum.KeyCode.RightShift,
    Debug          = false,
}

-- ============================================================
-- 🔌  STATE
-- ============================================================
local farmEnabled   = false
local jobDone       = false   -- สมัครงานแล้วหรือยัง
local isTweening    = false
local moverBP       = nil
local moverBG       = nil
local timeoutTask   = nil
local statsPickup   = 0

-- ============================================================
-- 🛠️  UTIL
-- ============================================================
local function log(...) if CONFIG.Debug then print("[Farm]",...) end end

local function distTo(pos)
    if not HRP or not HRP.Parent then return math.huge end
    return (HRP.Position - pos).Magnitude
end

local function destroyMovers()
    pcall(function() if moverBP then moverBP:Destroy() end end)
    pcall(function() if moverBG then moverBG:Destroy() end end)
    moverBP, moverBG = nil, nil
    isTweening = false
    if timeoutTask then task.cancel(timeoutTask) timeoutTask = nil end
end

local function matchName(name, keywords)
    local l = name:lower()
    for _, kw in ipairs(keywords) do
        if l:find(kw:lower()) then return true end
    end
    return false
end

local function getPivotPos(obj)
    if obj:IsA("BasePart") then return obj.Position
    elseif obj:IsA("Model") then
        local ok, cf = pcall(function() return obj:GetPivot() end)
        if ok then return cf.Position end
    end
    return nil
end

-- ============================================================
-- 🏃  SMOOTH MOVE (BodyPosition + BodyGyro)
-- ============================================================
local function smoothMoveTo(targetPos, onArrived)
    destroyMovers()
    isTweening = true

    moverBP = Instance.new("BodyPosition")
    moverBP.MaxForce  = Vector3.new(9e4, 9e4, 9e4)
    moverBP.P         = 8000
    moverBP.D         = 800
    moverBP.Position  = targetPos
    moverBP.Parent    = HRP

    moverBG = Instance.new("BodyGyro")
    moverBG.MaxTorque = Vector3.new(0, 9e4, 0)
    moverBG.P         = 2000
    moverBG.D         = 300
    moverBG.CFrame    = CFrame.new(HRP.Position, Vector3.new(targetPos.X, HRP.Position.Y, targetPos.Z))
    moverBG.Parent    = HRP

    local conn
    conn = RunService.Heartbeat:Connect(function()
        if not farmEnabled then destroyMovers(); conn:Disconnect(); return end
        if not HRP or not HRP.Parent then destroyMovers(); conn:Disconnect(); return end

        -- อัปเดตทิศทางหันหน้าเสมอ
        if moverBG then
            moverBG.CFrame = CFrame.new(HRP.Position, Vector3.new(targetPos.X, HRP.Position.Y, targetPos.Z))
        end

        if distTo(targetPos) <= CONFIG.ReachDistance then
            destroyMovers()
            conn:Disconnect()
            if onArrived then task.spawn(onArrived) end
        end
    end)

    -- timeout safety
    timeoutTask = task.delay(10, function()
        if conn.Connected then
            destroyMovers()
            conn:Disconnect()
            log("⚠️ Timeout ข้ามเป้า")
            if onArrived then task.spawn(onArrived) end
        end
    end)
end

-- ============================================================
-- 📋  หา NPC สมัครงาน
-- ============================================================
local function findJobNPC()
    for _, obj in ipairs(Workspace:GetDescendants()) do
        if matchName(obj.Name, CONFIG.JobNPCKeywords) then
            local pos = getPivotPos(obj)
            if pos then return obj, pos end
        end
    end
    return nil, nil
end

-- ============================================================
-- 📋  สมัครงาน (Interact กับ NPC)
-- ============================================================
local function registerJob(npc)
    -- ProximityPrompt
    for _, d in ipairs(npc:GetDescendants()) do
        if d:IsA("ProximityPrompt") then
            pcall(function() fireproximityprompt(d) end)
            log("✅ สมัครงานผ่าน ProximityPrompt")
            return true
        end
    end
    -- ClickDetector
    for _, d in ipairs(npc:GetDescendants()) do
        if d:IsA("ClickDetector") then
            pcall(function() fireclickdetector(d) end)
            log("✅ สมัครงานผ่าน ClickDetector")
            return true
        end
    end
    -- Touch
    local part = npc:IsA("BasePart") and npc or npc:FindFirstChildWhichIsA("BasePart")
    if part then
        pcall(function() firetouchinterest(HRP, part, 0) end)
        task.wait(0.1)
        pcall(function() firetouchinterest(HRP, part, 1) end)
        log("✅ สมัครงานผ่าน Touch")
        return true
    end
    return false
end

-- ============================================================
-- 📦  ยกกล่อง
-- ============================================================
local function pickupBox(obj)
    local done = false
    for _, d in ipairs(obj:GetDescendants()) do
        if d:IsA("ProximityPrompt") then
            pcall(function() fireproximityprompt(d) end); done = true; break
        end
    end
    if not done then
        for _, d in ipairs(obj:GetDescendants()) do
            if d:IsA("ClickDetector") then
                pcall(function() fireclickdetector(d) end); done = true; break
            end
        end
    end
    if not done then
        local part = obj:IsA("BasePart") and obj or obj:FindFirstChildWhichIsA("BasePart")
        if part then
            pcall(function() firetouchinterest(HRP, part, 0) end)
            task.wait(0.05)
            pcall(function() firetouchinterest(HRP, part, 1) end)
        end
    end
    statsPickup = statsPickup + 1
end

-- ============================================================
-- 🔍  หากล่องใกล้สุด
-- ============================================================
local function findNearestBox()
    local nearest, nearDist = nil, math.huge
    for _, obj in ipairs(Workspace:GetDescendants()) do
        if matchName(obj.Name, CONFIG.BoxKeywords) then
            local pos = getPivotPos(obj)
            if pos then
                local d = distTo(pos)
                if (CONFIG.ScanRadius == 0 or d <= CONFIG.ScanRadius) and d < nearDist then
                    nearDist, nearest = d, obj
                end
            end
        end
    end
    return nearest, nearDist
end

-- ============================================================
-- 🔁  FARM LOOP
-- ============================================================
local function farmLoop()
    -- Step 1: สมัครงานก่อน (ถ้ายังไม่ได้ทำ)
    if not jobDone then
        local npc, npcPos = findJobNPC()
        if npc and npcPos then
            log("🚶 เดินไปสมัครงาน...")
            smoothMoveTo(npcPos, function()
                task.wait(0.3)
                registerJob(npc)
                task.wait(1)
                jobDone = true
                log("✅ สมัครงานเสร็จแล้ว เริ่มฟาร์ม!")
            end)
            -- รอจนสมัครงานเสร็จ
            local waited = 0
            while not jobDone and farmEnabled do
                task.wait(0.5)
                waited = waited + 0.5
                if waited > 15 then
                    jobDone = true  -- timeout บังคับข้าม
                    break
                end
            end
        else
            log("⚠️ ไม่เจอ NPC สมัครงาน ข้ามไปฟาร์มเลย")
            jobDone = true
        end
    end

    -- Step 2: ฟาร์มกล่อง
    while farmEnabled do
        task.wait(CONFIG.ScanInterval)
        if isTweening then continue end

        local box, dist = findNearestBox()
        if not box then log("🔍 ไม่เจอกล่อง..."); continue end

        local pos = getPivotPos(box)
        if not pos then continue end

        if dist <= CONFIG.ReachDistance then
            pickupBox(box)
            task.wait(CONFIG.PickupDelay)
        else
            local captured = box
            smoothMoveTo(pos, function()
                task.wait(0.05)
                if captured and captured.Parent then
                    pickupBox(captured)
                end
                task.wait(CONFIG.PickupDelay)
            end)
        end
    end
end

