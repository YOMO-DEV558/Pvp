local function getPlayer(name)
    name = string.lower(name)
    for _, p in ipairs(Players:GetPlayers()) do
        if string.find(string.lower(p.Name), name) or string.find(string.lower(p.DisplayName), name) then
            return p
        end
    end
end

local function ForcePart(v)
    if not v:IsA("BasePart") then return end
    if v.Anchored or v.Parent:FindFirstChildOfClass("Humanoid") or v.Name == "Handle" then return end
    for _, obj in ipairs(v:GetChildren()) do
        if obj:IsA("BodyMover") or obj:IsA("RocketPropulsion") then obj:Destroy() end
    end
    v.CanCollide = false
    local att = Instance.new("Attachment", v)
    local ap  = Instance.new("AlignPosition", v)
    ap.MaxForce = math.huge
    ap.MaxVelocity = math.huge
    ap.Responsiveness = 9999
    ap.Attachment0 = att
    ap.Attachment1 = _attach1
end

local function ToggleBring(name)
    local player = getPlayer(name)
    if not player then return end
    Active = not Active
    if Active then
        local char = player.Character or player.CharacterAdded:Wait()
        local targetHRP = char:WaitForChild("HumanoidRootPart")
