local function startSnapLock()
    if snapConn then pcall(function() snapConn:Disconnect() end) end
    snapConn = RunService.Heartbeat:Connect(function()
        if not teleportActive or not lockedY then return end
        if not HumanoidRootPart then return end
        local p = HumanoidRootPart.Position
        if math.abs(p.Y - lockedY) > 0.05 then
            HumanoidRootPart.CFrame = CFrame.new(p.X, lockedY, p.Z)
        end
    end)
end

local function performSnap()
    if not HumanoidRootPart then return end
    startY = HumanoidRootPart.Position.Y
    local bottomY = startY - maxHeight
    HumanoidRootPart.CFrame = CFrame.new(HumanoidRootPart.Position.X, bottomY, HumanoidRootPart.Position.Z)
    lockedY = bottomY
end

local function stopSnap()
    teleportActive = false
    lockedY        = nil
    startY         = nil
end

