            Instance.new("UICorner", img).CornerRadius = UDim.new(0, 10)
            local stroke = Instance.new("UIStroke", img)
            stroke.Color = RARITY_COLORS[info.Rarity] or Color3.new(1,1,1)
            stroke.Thickness = 2
        end
    end
    BillboardCache[player] = bb
