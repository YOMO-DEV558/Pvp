local function CheckAndPickup()
    if not sucking then return end
    local dropped = Workspace:FindFirstChild("DroppedItems")
    if not dropped or not HumanoidRootPart then return end
    for _, item in ipairs(dropped:GetChildren()) do
        if item:IsA("Model") then
            local ok, cf = pcall(function()
                return item:GetPivot and item:GetPivot() or item:GetModelCFrame()
            end)
            if ok then
                local dist = (HumanoidRootPart.Position - cf.Position).Magnitude
                if dist <= 20 then
                    local now = tick()
                    if now - (lastPickupTimes[item] or 0) >= 0.3 then
                        pcall(function() NetGet("pickup_dropped_item", item) end)
                        lastPickupTimes[item] = now
                    end
                end
            end
        end
    end
end

