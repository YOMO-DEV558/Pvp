        end
    end)
    Players.PlayerRemoving:Connect(function(p)
        if espPlayers[p] then
            for _, obj in pairs(espPlayers[p].drawings) do
                if obj and obj.Destroy then pcall(function() obj:Destroy() end)
                elseif typeof(obj)=="table" and obj.Visible ~= nil then obj.Visible=false end
            end
            pcall(function() espPlayers[p].conn:Disconnect() end)
            espPlayers[p] = nil
        end
    end)
end

