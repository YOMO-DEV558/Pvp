local function createESP(player)
    if espPlayers[player] then return end
    local lines = {}
    for i = 1, 12 do
        local l = Drawing.new("Line")
        l.Color = Color3.new(1,1,1)
        l.Thickness = 2
        l.Visible = false
        lines[i] = l
    end
    local nameText = Drawing.new("Text")
    nameText.Size    = 14
    nameText.Center  = true
    nameText.Outline = true
    nameText.Font    = 2
    nameText.Color   = Color3.fromRGB(255,255,255)

    local distText = Drawing.new("Text")
    distText.Size    = 12
    distText.Center  = true
    distText.Outline = true
    distText.Color   = Color3.fromRGB(255,255,200)

    local hBg = Drawing.new("Square")
    hBg.Filled = false; hBg.Thickness = 1; hBg.Visible = false
    hBg.Color  = Color3.new(0,0,0)

    local hFg = Drawing.new("Square")
    hFg.Filled = true; hFg.Visible = false

    local hl = Instance.new("Highlight")
    hl.FillColor          = Color3.fromRGB(255,0,255)
    hl.OutlineColor       = Color3.fromRGB(255,0,255)
    hl.FillTransparency   = 1
    hl.OutlineTransparency= 0
    hl.DepthMode          = Enum.HighlightDepthMode.AlwaysOnTop
    hl.Enabled            = false
    pcall(function() hl.Parent = player.Character or Workspace end)

    local drawings = {nameText, distText, hBg, hFg, hl}
    for _, ln in ipairs(lines) do table.insert(drawings, ln) end

    local EDGES = {{1,2},{1,3},{1,5},{2,4},{2,6},{3,4},{3,7},{4,8},{5,6},{5,7},{6,8},{7,8}}
    local conn = RunService.RenderStepped:Connect(function()
        if not player or not player.Character or not player.Character:FindFirstChild("HumanoidRootPart") then
            for _, ln in ipairs(lines) do ln.Visible = false end
            nameText.Visible = false; distText.Visible = false
            hBg.Visible = false; hFg.Visible = false; hl.Enabled = false
            return
        end
        if hl and hl.Parent then hl.Adornee = player.Character end
        local hrp    = player.Character.HumanoidRootPart
        local humanoid = player.Character:FindFirstChild("Humanoid")
        local dist   = 0
        if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
            dist = (hrp.Position - LocalPlayer.Character.HumanoidRootPart.Position).Magnitude
        end
        local thick = math.clamp(500 / math.max(dist, 1), 0.5, 2)
        local cf    = player.Character:GetPivot()
        local sz    = Vector3.new(3.5, 7, 2)
        local hs    = sz / 2
        local corners = {
            cf*Vector3.new(-hs.X,-hs.Y,-hs.Z), cf*Vector3.new(-hs.X,-hs.Y, hs.Z),
            cf*Vector3.new(-hs.X, hs.Y,-hs.Z), cf*Vector3.new(-hs.X, hs.Y, hs.Z),
            cf*Vector3.new( hs.X,-hs.Y,-hs.Z), cf*Vector3.new( hs.X,-hs.Y, hs.Z),
            cf*Vector3.new( hs.X, hs.Y,-hs.Z), cf*Vector3.new( hs.X, hs.Y, hs.Z)
        }
        local vp = {}
        local minX,maxX,minY,maxY = math.huge,-math.huge,math.huge,-math.huge
        local hasFront = false
        for i, w in ipairs(corners) do
            local sp, on = Camera:WorldToViewportPoint(w)
            vp[i] = {pos=sp, on=on}
            if on and sp.Z > 0 then
                hasFront = true
                minX=math.min(minX,sp.X); maxX=math.max(maxX,sp.X)
                minY=math.min(minY,sp.Y); maxY=math.max(maxY,sp.Y)
            end
        end
        if not hasFront then
            for _,ln in ipairs(lines) do ln.Visible=false end
            nameText.Visible=false; distText.Visible=false
            hBg.Visible=false; hFg.Visible=false; hl.Enabled=false
            return
        end
        local width   = maxX - minX
        local centerX = (minX+maxX)/2
        local boxColor = Color3.new(1,1,1)
        if humanoid and humanoid.Health > 0 then
            local perc = humanoid.Health / (humanoid.MaxHealth > 0 and humanoid.MaxHealth or 1)
            boxColor = Color3.fromHSV(perc*0.333, 0.5, 1)
        end
        if boxESPEnabled then
            for i, edge in ipairs(EDGES) do
                local a,b = vp[edge[1]], vp[edge[2]]
                if a and b and a.on and b.on then
                    lines[i].From = Vector2.new(a.pos.X,a.pos.Y)
                    lines[i].To   = Vector2.new(b.pos.X,b.pos.Y)
                    lines[i].Color= boxColor; lines[i].Thickness=thick; lines[i].Visible=true
                else lines[i].Visible=false end
            end
        else
            for _,ln in ipairs(lines) do ln.Visible=false end
        end
        local topY = minY
        if healthESPEnabled and humanoid and humanoid.Health > 0 then
            local perc = humanoid.Health / (humanoid.MaxHealth > 0 and humanoid.MaxHealth or 1)
            local bh = 4; local bw = math.max(width, 50)
            local bx = width < 50 and centerX-25 or minX
            hBg.Position=Vector2.new(bx,topY-bh-2); hBg.Size=Vector2.new(bw,bh); hBg.Visible=true
            hFg.Position=Vector2.new(bx,topY-bh-2); hFg.Size=Vector2.new(bw*perc,bh)
            hFg.Color=Color3.fromHSV(perc*0.333,0.5,1); hFg.Visible=true
            topY = topY - bh - 2
        else hBg.Visible=false; hFg.Visible=false end
        nameText.Text    = nameESPEnabled and player.Name or ""
        nameText.Color   = isPlayerExcluded(player.Name) and Color3.fromRGB(0,255,0) or Color3.fromRGB(255,255,255)
        nameText.Position= Vector2.new(centerX, topY-16); nameText.Visible=nameESPEnabled
        distText.Text    = distanceESPEnabled and string.format("%.0f studs", dist) or ""
        distText.Position= Vector2.new(centerX, maxY+4);  distText.Visible=distanceESPEnabled
        hl.Enabled       = highlightEnabled
    end)
    espPlayers[player] = {conn=conn, drawings=drawings}
end

local function loadESP()
    for _, p in pairs(Players:GetPlayers()) do
